{
  "id": null,
  "uid": "signalk-navigation",
  "title": "Navigation",
  "schemaVersion": 39,
  "editable": true,
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "Speed Over Ground",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "velocityknot",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "signalk-questdb"
          },
          "rawSql": "SELECT ts AS \"time\", avg(value) * 1.94384 AS \"SOG\" FROM signalk WHERE path = 'navigation.speedOverGround' AND context = 'self' AND ts >= $__timeFrom() AND ts <= $__timeTo() SAMPLE BY 10s",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Course Over Ground",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "degree",
          "min": 0,
          "max": 360,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "signalk-questdb"
          },
          "rawSql": "SELECT ts AS \"time\", avg(value) * 57.2958 AS \"COG\" FROM signalk WHERE path = 'navigation.courseOverGroundTrue' AND context = 'self' AND ts >= $__timeFrom() AND ts <= $__timeTo() SAMPLE BY 10s",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "signalk-questdb"
          },
          "rawSql": "SELECT ts AS \"time\", avg(value) AS \"Depth\" FROM signalk WHERE path = 'environment.depth.belowTransducer' AND context = 'self' AND ts >= $__timeFrom() AND ts <= $__timeTo() SAMPLE BY 10s",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Heading",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "degree",
          "min": 0,
          "max": 360,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "signalk-questdb"
          },
          "rawSql": "SELECT ts AS \"time\", avg(value) * 57.2958 AS \"Heading\" FROM signalk WHERE path = 'navigation.headingTrue' AND context = 'self' AND ts >= $__timeFrom() AND ts <= $__timeTo() SAMPLE BY 10s",
          "format": "time_series",
          "refId": "A"
        }
      ]
    }
  ]
}
