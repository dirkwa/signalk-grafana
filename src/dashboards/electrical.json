{
  "id": null,
  "uid": "signalk-electrical",
  "title": "Electrical",
  "schemaVersion": 39,
  "editable": true,
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "Battery Voltage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT ts AS \"time\", avg(value) AS \"Voltage\" FROM signalk WHERE path LIKE 'electrical.batteries.%.voltage' AND context = 'self' AND ts >= $__timeFrom() AND ts <= $__timeTo() SAMPLE BY 10s",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Battery Current",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
