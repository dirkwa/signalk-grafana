          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT ts AS \"time\", avg(value) AS \"Current\" FROM signalk WHERE path LIKE 'electrical.batteries.%.current' AND context = 'self' AND ts >= $__timeFrom() AND ts <= $__timeTo() SAMPLE BY 10s",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
