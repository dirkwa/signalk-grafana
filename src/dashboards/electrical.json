{
  "title": "Electrical",
  "uid": "signalk-electrical",
  "editable": true,
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "Battery Voltage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT ts AS time, avg(value) AS \"Voltage\" FROM signalk WHERE path LIKE 'electrical.batteries.%.voltage' AND context = 'self' AND $__timeFilter(ts) SAMPLE BY $__interval",
          "format": "time_series"
        }
      ]
    },
    {
      "title": "Battery Current",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT ts AS time, avg(value) AS \"Current\" FROM signalk WHERE path LIKE 'electrical.batteries.%.current' AND context = 'self' AND $__timeFilter(ts) SAMPLE BY $__interval",
          "format": "time_series"
        }
      ]
    },
    {
      "title": "AC Power",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT ts AS time, path, avg(value) AS \"Power\" FROM signalk WHERE path LIKE 'electrical.ac.%.total.realPower' AND context = 'self' AND $__timeFilter(ts) SAMPLE BY $__interval",
          "format": "time_series"
        }
      ]
    },
    {
      "title": "AC Voltage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT ts AS time, avg(value) AS \"Voltage\" FROM signalk WHERE path LIKE 'electrical.ac.%.average.lineNeutralVoltage' AND context = 'self' AND $__timeFilter(ts) SAMPLE BY $__interval",
          "format": "time_series"
        }
      ]
    }
  ]
}
