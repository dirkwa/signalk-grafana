            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT ts AS \"time\", avg(value) AS \"Power\" FROM signalk WHERE path LIKE 'electrical.ac.%.total.realPower' AND context = 'self' AND ts >= $__timeFrom() AND ts <= $__timeTo() SAMPLE BY 10s",
          "format": "time_series",
          "refId": "A"
