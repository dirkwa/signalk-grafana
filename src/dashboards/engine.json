{
  "id": null,
  "uid": "signalk-engine",
  "title": "Engine",
  "schemaVersion": 39,
  "editable": true,
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "Engine RPM",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "rpm",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "signalk-questdb"
          },
          "rawSql": "SELECT ts AS \"time\", avg(value) * 60 AS \"RPM\" FROM signalk WHERE path LIKE 'propulsion.%.revolutions' AND context = 'self' AND ts >= $__timeFrom() AND ts <= $__timeTo() SAMPLE BY 10s",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Coolant Temperature",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "signalk-questdb"
          },
          "rawSql": "SELECT ts AS \"time\", avg(value) - 273.15 AS \"Coolant\" FROM signalk WHERE path LIKE 'propulsion.%.coolantTemperature' AND context = 'self' AND ts >= $__timeFrom() AND ts <= $__timeTo() SAMPLE BY 10s",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Oil Pressure",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "pressurepsi",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "signalk-questdb"
          },
          "rawSql": "SELECT ts AS \"time\", avg(value) * 0.000145038 AS \"Oil PSI\" FROM signalk WHERE path LIKE 'propulsion.%.oilPressure' AND context = 'self' AND ts >= $__timeFrom() AND ts <= $__timeTo() SAMPLE BY 10s",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Fuel Level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "signalk-questdb"
          },
          "rawSql": "SELECT ts AS \"time\", avg(value) AS \"Fuel\" FROM signalk WHERE path LIKE 'tanks.fuel.%.currentLevel' AND context = 'self' AND ts >= $__timeFrom() AND ts <= $__timeTo() SAMPLE BY 10s",
          "format": "time_series",
          "refId": "A"
        }
      ]
    }
  ]
}
